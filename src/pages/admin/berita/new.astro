---
import AdminLayout from '../../../components/AdminLayout.astro';
import BeritaEditor from '../../../components/BeritaEditor.astro';
const errors = Astro.url.searchParams.get('errors')?.split(',') ?? [];
---

<AdminLayout title="Tulis Berita Baru" breadcrumb="Berita / Tulis Baru">

  {errors.length > 0 && (
    <div role="alert" class="mb-4 p-4 rounded-lg text-sm" style="background:#FEE2E2; color:#991B1B; border:1px solid #FECACA;">
      <p class="font-heading font-semibold mb-1">Berita belum bisa diterbitkan:</p>
      <ul class="list-disc list-inside space-y-0.5">
        {errors.map(e => <li>{decodeURIComponent(e)}</li>)}
      </ul>
    </div>
  )}

  <BeritaEditor action="/api/admin/berita" />

</AdminLayout>

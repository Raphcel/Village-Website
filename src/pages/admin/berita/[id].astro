---
import AdminLayout from '../../../components/AdminLayout.astro';
import BeritaEditor from '../../../components/BeritaEditor.astro';
import { getBeritaById } from '../../../lib/db/berita';

const { id } = Astro.params as { id: string };
import { getEnv } from '@lib/env';
const env = getEnv();
const berita = env ? await getBeritaById(Number(id), env.DB) : null;
if (!berita) return Astro.redirect('/admin/berita');

const coverMedia = berita.cover_media_id && env
  ? await env.DB.prepare('SELECT r2_key_display FROM media WHERE id = ?').bind(berita.cover_media_id).first<{ r2_key_display: string }>()
  : null;
const coverUrl = coverMedia ? `/api/media/${encodeURIComponent(coverMedia.r2_key_display)}` : null;

const saved = Astro.url.searchParams.get('saved');
const published = Astro.url.searchParams.get('published');
---

<AdminLayout title={`Edit: ${berita.judul}`} breadcrumb={`Berita / Edit`}>

  {published && (
    <div role="status" class="mb-4 p-4 rounded-lg text-sm font-medium" style="background:#D1FAE5; color:#065F46; border:1px solid #6EE7B7;">
      Berita berhasil diterbitkan! Artikel sudah tayang di situs publik dan bisa dibagikan.
    </div>
  )}
  {saved && !published && (
    <div role="status" class="mb-4 p-3 rounded-lg text-sm font-medium" style="background:#D1FAE5; color:#065F46; border:1px solid #6EE7B7;">
      Draf berita berhasil disimpan.
    </div>
  )}

  <BeritaEditor
    action={`/api/admin/berita/${berita.id}`}
    judul={berita.judul}
    contentHtml={berita.content_html}
    coverMediaId={berita.cover_media_id}
    coverUrl={coverUrl}
  />

</AdminLayout>

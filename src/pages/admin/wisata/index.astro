---
import AdminLayout from '../../../components/AdminLayout.astro';
import { getAllWisata } from '../../../lib/db/wisata';

import { getEnv } from '@lib/env';
const env = getEnv();
const wisataList = env ? await getAllWisata(env.DB) : [];
const deleted = Astro.url.searchParams.get('deleted');
---

<AdminLayout title="Kelola Wisata" breadcrumb="Wisata">

  {deleted && (
    <div role="status" class="mb-4 p-3 rounded-lg text-sm font-medium" style="background:#D1FAE5; color:#065F46; border:1px solid #6EE7B7;">
      Destinasi wisata berhasil dihapus.
    </div>
  )}

  <div class="flex items-center justify-between mb-6">
    <h2 class="font-heading font-bold text-xl" style="color:var(--color-primary);">Destinasi Wisata</h2>
    <a href="/admin/wisata/new"
      class="px-4 py-2 rounded-lg font-heading font-semibold text-white text-sm focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent"
      style="background:var(--color-cta); min-height:44px; display:flex; align-items:center;">
      + Tambah Wisata Baru
    </a>
  </div>

  <div class="bg-white rounded-xl border border-border overflow-hidden" style="box-shadow:var(--shadow-sm);">
    {wisataList.length === 0 ? (
      <div class="p-8 text-center text-text-muted">Belum ada destinasi wisata.</div>
    ) : (
      <table class="w-full text-sm">
        <thead style="background:#F8FAFC;">
          <tr class="border-b border-border">
            <th class="text-left px-4 py-3 font-heading font-semibold">Nama</th>
            <th class="text-left px-4 py-3 font-heading font-semibold hidden md:table-cell">Status</th>
            <th class="text-left px-4 py-3 font-heading font-semibold hidden md:table-cell">Tanggal</th>
            <th class="px-4 py-3 font-heading font-semibold">Aksi</th>
          </tr>
        </thead>
        <tbody>
          {wisataList.map((w) => (
            <tr class="border-b border-border last:border-0 hover:bg-sand/30 transition-colors">
              <td class="px-4 py-3 font-medium">{w.nama}</td>
              <td class="px-4 py-3 hidden md:table-cell">
                <span class:list={['inline-flex items-center gap-1.5 px-2 py-0.5 rounded-sm text-xs font-medium',
                  w.status === 'published' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600']}>
                  <span class:list={['w-1.5 h-1.5 rounded-full', w.status === 'published' ? 'bg-green-500' : 'bg-gray-400']} aria-hidden="true"></span>
                  {w.status === 'published' ? 'Terbit' : 'Draf'}
                </span>
              </td>
              <td class="px-4 py-3 text-text-muted hidden md:table-cell">
                {new Date(w.updated_at).toLocaleDateString('id-ID')}
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center justify-center gap-2">
                  <a href={`/admin/wisata/${w.id}`}
                    class="px-3 py-1.5 rounded-md text-xs font-heading font-medium border transition-colors hover:bg-primary hover:text-white focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent"
                    style="border-color:var(--color-primary); color:var(--color-primary);">
                    Sunting
                  </a>
                  <a href={`/wisata/${w.slug}`} target="_blank"
                    class="px-3 py-1.5 rounded-md text-xs font-heading font-medium border transition-colors hover:bg-sand focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent"
                    style="border-color:var(--color-border); color:var(--color-text-muted);">
                    Lihat
                  </a>
                  <form method="POST" action="/api/admin/wisata/delete"
                    onsubmit="return confirm('Hapus destinasi ini? Tindakan tidak dapat dibatalkan.')">
                    <input type="hidden" name="id" value={String(w.id)} />
                    <button type="submit"
                      class="px-3 py-1.5 rounded-md text-xs font-heading font-medium border transition-colors hover:bg-red-50 hover:text-red-600 cursor-pointer focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent"
                      style="border-color:#FECACA; color:#DC2626;">
                      Hapus
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

</AdminLayout>

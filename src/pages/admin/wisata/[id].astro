---
import AdminLayout from '../../../components/AdminLayout.astro';
import AdminEditorToolbar from '../../../components/AdminEditorToolbar.astro';
import AdminFotoManager from '../../../components/AdminFotoManager.astro';
import { getWisataById } from '../../../lib/db/wisata';
import { getMediaForEntity } from '../../../lib/db/media';

const { id } = Astro.params as { id: string };
import { getEnv } from '@lib/env';
const env = getEnv();
const wisata = env ? await getWisataById(Number(id), env.DB) : null;
if (!wisata) return Astro.redirect('/admin/wisata');

const mediaList = env ? await getMediaForEntity('wisata', wisata.id, env.DB) : [];

const saved = Astro.url.searchParams.get('saved');
---

<AdminLayout title={`Edit: ${wisata.nama}`} breadcrumb={`Wisata / ${wisata.nama}`}>

  {saved && (
    <div role="status" class="mb-4 p-3 rounded-lg text-sm font-medium" style="background:#D1FAE5; color:#065F46; border:1px solid #6EE7B7;">
      Destinasi wisata berhasil disimpan.
    </div>
  )}

  <div class="max-w-3xl">
    <h2 class="font-heading font-bold text-xl mb-6" style="color:var(--color-primary);">Edit Destinasi Wisata</h2>

    <form method="POST" action={`/api/admin/wisata/${wisata.id}`} class="space-y-5">

      <div>
        <label for="nama" class="block font-heading font-medium text-sm mb-1.5">
          Nama Wisata <span>*</span> <span class="font-normal text-text-muted">(wajib)</span>
        </label>
        <input type="text" id="nama" name="nama" required value={wisata.nama}
          class="w-full rounded-lg border px-4 py-3 text-base focus:outline-none"
          style="border-color:var(--color-border); min-height:44px;" />
      </div>

      <div>
        <label for="deskripsi_html" class="block font-heading font-medium text-sm mb-1.5">Deskripsi</label>
        <AdminEditorToolbar />
        <div id="editor-deskripsi" contenteditable="true"
          class="w-full min-h-40 border border-t-0 rounded-b-lg px-4 py-3 text-base focus:outline-none"
          style="border-color:var(--color-border);"
          set:html={wisata.deskripsi_html}></div>
        <input type="hidden" id="deskripsi_html" name="deskripsi_html" value={wisata.deskripsi_html} />
      </div>

      <div>
        <label for="status" class="block font-heading font-medium text-sm mb-1.5">Status</label>
        <select id="status" name="status"
          class="rounded-lg border px-4 py-3 text-base focus:outline-none"
          style="border-color:var(--color-border); min-height:44px; min-width:160px;">
          <option value="draft" selected={wisata.status === 'draft'}>Draf</option>
          <option value="published" selected={wisata.status === 'published'}>Terbitkan</option>
        </select>
      </div>

      <div class="sticky bottom-0 bg-white border-t border-border -mx-4 md:-mx-6 px-4 md:px-6 py-3 flex justify-end gap-3" style="box-shadow:0 -2px 8px rgba(0,0,0,.06);">
        <a href="/admin/wisata"
          class="px-4 py-2 rounded-lg font-heading font-medium text-sm border transition-colors hover:bg-sand"
          style="border-color:var(--color-border); min-height:44px; display:flex; align-items:center;">
          Batal
        </a>
        <button type="submit"
          class="px-5 py-2 rounded-lg font-heading font-semibold text-white text-sm cursor-pointer"
          style="background:var(--color-cta); min-height:44px;">
          Simpan
        </button>
      </div>
    </form>

    <AdminFotoManager
      ownerType="wisata"
      ownerId={wisata.id}
      mediaList={mediaList}
      purgePaths={['/', '/wisata', `/wisata/${wisata.slug}`, '/peta']}
      defaultAlt={wisata.nama}
    />
  </div>

</AdminLayout>

<style>
  #editor-deskripsi h2 { font-size:1.125rem; font-weight:700; margin:1rem 0 .25rem; }
  #editor-deskripsi ul { list-style:disc; padding-left:1.5rem; }
  #editor-deskripsi ol { list-style:decimal; padding-left:1.5rem; }
</style>

<script>
  import { initEditor } from '../../../scripts/admin-editor';

  const editor = document.getElementById('editor-deskripsi') as HTMLDivElement;
  const hidden = document.getElementById('deskripsi_html') as HTMLInputElement;
  document.querySelector('form')?.addEventListener('submit', () => { hidden.value = editor.innerHTML; });
  initEditor(editor, hidden);
</script>

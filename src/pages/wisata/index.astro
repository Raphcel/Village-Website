---
import Layout from '../../components/Layout.astro';
import { getPublishedWisata } from '../../lib/db/wisata';
import { excerpt } from '../../lib/db/berita';
import { getCoversForType, mediaUrl } from '../../lib/db/media';
import { getEnv } from '@lib/env';

const env = getEnv();
const [wisataList, covers] = await Promise.all([
  env ? getPublishedWisata(env.DB) : [],
  env ? getCoversForType('wisata', env.DB) : new Map(),
]);

const demoWisata = [
  { slug: 'pantai-loji', nama: 'Pantai Loji', deskripsi_html: 'Garis pantai sepanjang ±4 km di tepi Samudra Hindia, bagian dari kawasan Geopark Ciletuh-Palabuhanratu.', img: '/images/pantai_loji.png', tag: 'Pantai' },
  { slug: 'danau-talanca', nama: 'Danau Talanca', deskripsi_html: 'Danau seluas 20 hektar yang berpotensi dikembangkan untuk wisata air sekaligus kawasan perikanan.', img: '/images/pantai_loji.png', tag: 'Wisata Air' },
  { slug: 'muara-loji-sidat', nama: 'Muara Loji (Kampung Sidat)', deskripsi_html: 'Kawasan muara tempat budidaya sidat (belut), berpotensi sebagai wisata edukasi dan penelitian.', img: '/images/nelayan.png', tag: 'Edukasi' },
  { slug: 'air-panas-sawah-beura', nama: 'Pemandian Air Panas Sawah Beura', deskripsi_html: 'Sumber air panas alami di Kampung Sawah Beura yang berpotensi menjadi wisata pemandian.', img: '/images/pantai_loji.png', tag: 'Alam' },
  { slug: 'puncak-gelendrung', nama: 'Puncak Gelendrung', deskripsi_html: 'Puncak di kawasan Gunung Rompang dengan panorama alam yang cocok untuk paralayang.', img: '/images/pantai_loji.png', tag: 'Alam' },
  { slug: 'benteng-loji', nama: 'Benteng Peninggalan Belanda', deskripsi_html: 'Benteng pertahanan masa kolonial di pesisir desa, asal-usul nama Desa Loji (dari kata Loge).', img: '/images/pantai_loji.png', tag: 'Sejarah' },
];

const getWisataImg = (slug: string) => {
  if (slug === 'pantai-loji') return '/images/pantai_loji.png';
  if (slug === 'pantai-karang-sari') return '/images/karang_sari.png';
  return '/images/pantai_loji.png';
};

const displayList = wisataList.length > 0
  ? wisataList.map(w => {
      const cover = covers.get(w.id);
      return { slug: w.slug, nama: w.nama, deskripsi_html: w.deskripsi_html, img: cover ? mediaUrl(cover) : getWisataImg(w.slug), tag: 'Wisata' };
    })
  : demoWisata;
---

<Layout
  title="Wisata | Desa Loji"
  description="Jelajahi 8 destinasi wisata unggulan Desa Loji: pantai, danau, situs sejarah, dan budaya pesisir Sukabumi, bagian dari Geopark Ciletuh-Palabuhanratu."
>

<!-- Hero -->
<section class="relative">
  <div class="h-48 sm:h-64 overflow-hidden">
    <img
      src="/images/pantai_loji.png"
      alt="Pantai Loji dan kawasan Geopark Ciletuh"
      class="w-full h-full object-cover"
    />
  </div>
  <div class="absolute inset-0" style="background: rgba(10,54,80,0.55);"></div>
  <div class="absolute inset-0 flex items-end">
    <div class="mx-auto max-w-[1152px] px-4 sm:px-6 w-full pb-6 text-white">
      <nav aria-label="Breadcrumb" class="text-sm text-white/80 flex items-center gap-1.5">
        <a href="/" class="hover:text-white">Beranda</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <span class="font-medium">Wisata</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-heading font-extrabold mt-1">Destinasi Wisata Desa Loji</h1>
      <p class="text-white/85 mt-1">Temukan keindahan alam dan budaya pesisir selatan Sukabumi</p>
    </div>
  </div>
</section>

<main id="main" class="mx-auto max-w-[1152px] px-4 sm:px-6 py-10">
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {displayList.map(w => (
      <article class="group bg-white border border-line rounded-2xl overflow-hidden shadow-[0_4px_10px_rgba(15,36,51,.08)] hover:shadow-[0_12px_24px_rgba(15,36,51,.12)] hover:border-accent transition-all flex flex-col">
        <a href={`/wisata/${w.slug}`} class="block aspect-[16/10] overflow-hidden relative">
          {w.img ? (
            <img
              src={w.img}
              alt={w.nama}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          ) : (
            <div class="w-full h-full" style="background: linear-gradient(135deg, #0E4A6E, #0E9AA7);"></div>
          )}
          <span class="absolute top-3 left-3 bg-white/90 backdrop-blur text-primary text-xs font-heading font-semibold px-2.5 py-1 rounded-full">{w.tag}</span>
        </a>
        <div class="p-5 flex flex-col flex-1">
          <h2 class="font-heading font-semibold text-ink text-lg group-hover:text-primary transition-colors">
            <a href={`/wisata/${w.slug}`}>{w.nama}</a>
          </h2>
          <p class="text-sm text-muted mt-1 flex-1 line-clamp-2">{excerpt(w.deskripsi_html, 100)}</p>
          <a href={`/wisata/${w.slug}`} class="inline-flex items-center gap-1.5 mt-4 text-accent font-heading font-semibold text-sm hover:underline">
            Jelajahi <i data-lucide="arrow-right" class="w-4 h-4"></i>
          </a>
        </div>
      </article>
    ))}
  </div>
</main>

</Layout>

<script is:inline>
  setTimeout(() => { if (typeof lucide !== 'undefined') lucide.createIcons(); }, 300);
</script>

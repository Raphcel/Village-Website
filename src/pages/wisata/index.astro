---
import Layout from '../../components/Layout.astro';
import { getPublishedWisata } from '../../lib/db/wisata';
import { excerpt } from '../../lib/db/berita';
import { getEnv } from '@lib/env';

const env = getEnv();
const wisataList = env ? await getPublishedWisata(env.DB) : [];

const demoWisata = [
  { slug: 'pantai-loji', nama: 'Pantai Loji', deskripsi_html: 'Pantai pesisir selatan yang memukau, gerbang utama menuju Geopark Ciletuh. Ombak bersih, pasir hitam vulkanik, dan pemandangan matahari terbenam yang spektakuler.', img: '/images/pantai_loji.png', tag: 'Pantai' },
  { slug: 'kuil-dewi-kwan-im', nama: 'Kuil Dewi Kwan Im', deskripsi_html: 'Vihara Nam Hai Kwan Se Im Pu Sa dengan arsitektur khas Tionghoa yang berdiri indah di tepi pantai. Tempat ibadah dan wisata budaya yang tenang.', img: '/images/karang_sari.png', tag: 'Budaya' },
  { slug: 'gerbang-geopark-ciletuh', nama: 'Gerbang Geopark Ciletuh', deskripsi_html: 'Pintu masuk utama ke Geopark Ciletuh yang diakui UNESCO. Pemandangan tebing, muara, dan hutan pesisir yang dramatis.', img: '/images/pantai_loji.png', tag: 'Alam' },
  { slug: 'muara-sungai-loji', nama: 'Muara Sungai Loji', deskripsi_html: 'Pertemuan sungai dan laut yang menciptakan ekosistem mangrove unik. Lokasi favorit memancing dan pengamatan burung.', img: '/images/pantai_loji.png', tag: 'Alam' },
  { slug: 'spot-sunset-karang', nama: 'Spot Sunset Karang', deskripsi_html: 'Tebing karang yang menjorok ke laut — tempat terbaik menyaksikan matahari terbenam di cakrawala Samudra Hindia.', img: '/images/karang_sari.png', tag: 'Pemandangan' },
  { slug: 'pasar-ikan-nelayan', nama: 'Pasar Ikan Nelayan', deskripsi_html: 'Pasar ikan tradisional tempat nelayan menjual hasil tangkapan segar langsung dari perahu. Aktif dari dini hari hingga pagi.', img: '/images/nelayan.png', tag: 'Budaya' },
];

const getWisataImg = (slug: string) => {
  if (slug === 'pantai-loji') return '/images/pantai_loji.png';
  if (slug === 'pantai-karang-sari') return '/images/karang_sari.png';
  return '/images/pantai_loji.png';
};

const displayList = wisataList.length > 0
  ? wisataList.map(w => ({ slug: w.slug, nama: w.nama, deskripsi_html: w.deskripsi_html, img: getWisataImg(w.slug), tag: 'Wisata' }))
  : demoWisata;
---

<Layout
  title="Wisata — Desa Loji"
  description="Jelajahi 6 destinasi wisata unggulan Desa Loji: pantai, geopark, kuil, dan budaya pesisir Sukabumi."
>

<!-- Hero -->
<section class="relative">
  <div class="h-48 sm:h-64 overflow-hidden">
    <img
      src="/images/pantai_loji.png"
      alt="Pantai Loji dan kawasan Geopark Ciletuh"
      class="w-full h-full object-cover"
    />
  </div>
  <div class="absolute inset-0" style="background: rgba(10,54,80,0.55);"></div>
  <div class="absolute inset-0 flex items-end">
    <div class="mx-auto max-w-[1152px] px-4 sm:px-6 w-full pb-6 text-white">
      <nav aria-label="Breadcrumb" class="text-sm text-white/80 flex items-center gap-1.5">
        <a href="/" class="hover:text-white">Beranda</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <span class="font-medium">Wisata</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-heading font-extrabold mt-1">Destinasi Wisata Desa Loji</h1>
      <p class="text-white/85 mt-1">Temukan keindahan alam dan budaya pesisir selatan Sukabumi</p>
    </div>
  </div>
</section>

<main id="main" class="mx-auto max-w-[1152px] px-4 sm:px-6 py-10">
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {displayList.map(w => (
      <article class="group bg-white border border-line rounded-2xl overflow-hidden shadow-[0_4px_10px_rgba(15,36,51,.08)] hover:shadow-[0_12px_24px_rgba(15,36,51,.12)] hover:border-accent transition-all flex flex-col">
        <a href={`/wisata/${w.slug}`} class="block aspect-[16/10] overflow-hidden relative">
          {w.img ? (
            <img
              src={w.img}
              alt={w.nama}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          ) : (
            <div class="w-full h-full" style="background: linear-gradient(135deg, #0E4A6E, #0E9AA7);"></div>
          )}
          <span class="absolute top-3 left-3 bg-white/90 backdrop-blur text-primary text-xs font-heading font-semibold px-2.5 py-1 rounded-full">{w.tag}</span>
        </a>
        <div class="p-5 flex flex-col flex-1">
          <h2 class="font-heading font-semibold text-ink text-lg group-hover:text-primary transition-colors">
            <a href={`/wisata/${w.slug}`}>{w.nama}</a>
          </h2>
          <p class="text-sm text-muted mt-1 flex-1 line-clamp-2">{excerpt(w.deskripsi_html, 100)}</p>
          <a href={`/wisata/${w.slug}`} class="inline-flex items-center gap-1.5 mt-4 text-accent font-heading font-semibold text-sm hover:underline">
            Jelajahi <i data-lucide="arrow-right" class="w-4 h-4"></i>
          </a>
        </div>
      </article>
    ))}
  </div>
</main>

</Layout>

<script is:inline>
  setTimeout(() => { if (typeof lucide !== 'undefined') lucide.createIcons(); }, 300);
</script>

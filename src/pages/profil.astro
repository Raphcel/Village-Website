---
import Layout from '../components/Layout.astro';
import { getSection } from '../lib/db/page-section';
import { getPengaturan } from '../lib/db/pengaturan';
import { getEnv } from '@lib/env';

const env = getEnv();
const [umum, geografis, sejarah, s] = await Promise.all([
  env ? getSection('profil-umum', env.DB) : null,
  env ? getSection('profil-geografis', env.DB) : null,
  env ? getSection('profil-sejarah', env.DB) : null,
  env ? getPengaturan(env.DB) : {},
]);

const fmt = (n: number) => n.toLocaleString('id-ID');
const barPct = (v: number, max: number) => Math.max(4, Math.round((v / max) * 100));

const stUmum = JSON.parse(s.stat_umum ?? '{}');
const dusunData: { label: string; l: number; p: number; kk: number }[] = JSON.parse(s.stat_dusun ?? '[]');
const dusunMax = Math.max(1, ...dusunData.flatMap(d => [d.l, d.p]));

const totalPenduduk = dusunData.reduce((sum, d) => sum + d.l + d.p, 0);

const umurData: { label: string; value: number }[] = JSON.parse(s.stat_umur ?? '[]');
const umurMax = Math.max(1, ...umurData.map(d => d.value));

const pendidikanData: { label: string; value: number }[] = JSON.parse(s.stat_pendidikan ?? '[]');
const pendidikanMax = Math.max(1, ...pendidikanData.map(d => d.value));

const pencaharianData: { label: string; value: number }[] = JSON.parse(s.stat_pencaharian ?? '[]');
const pencaharianMax = Math.max(1, ...pencaharianData.map(d => d.value));
---

<Layout
  title="Profil Desa | Desa Loji"
  description="Profil lengkap Desa Loji: sejarah, kondisi geografis, visi misi, dan gambaran desa pesisir Kecamatan Simpenan Sukabumi."
>

<!-- Hero -->
<section class="relative">
  <div class="h-48 sm:h-64 overflow-hidden">
    <img
      src="/images/pantai_loji.png"
      alt="Pantai dan alam Desa Loji"
      class="w-full h-full object-cover"
    />
  </div>
  <div class="absolute inset-0" style="background: rgba(10,54,80,0.6);"></div>
  <div class="absolute inset-0 flex items-end">
    <div class="mx-auto max-w-[1152px] px-4 sm:px-6 w-full pb-6 text-white">
      <nav aria-label="Breadcrumb" class="text-sm text-white/80 flex items-center gap-1.5">
        <a href="/" class="hover:text-white">Beranda</a>
        <i data-lucide="chevron-right" class="w-4 h-4"></i>
        <span class="font-medium">Profil Desa</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-heading font-extrabold mt-1">Profil Desa Loji</h1>
      <p class="text-white/85 mt-1 max-w-xl">Kecamatan Simpenan, Kabupaten Sukabumi, Jawa Barat</p>
    </div>
  </div>
</section>

<!-- Sticky subnav -->
<div class="subnav sticky top-16 z-30 bg-white border-b border-line" style="scroll-behavior:smooth;">
  <div class="mx-auto max-w-[1152px] px-4 sm:px-6 py-2 flex gap-2 overflow-x-auto">
    {[
      ['#umum', 'Umum'],
      ['#geografis', 'Geografis'],
      ['#demografi', 'Demografi'],
      ['#sejarah', 'Sejarah'],
      ['#peta', 'Peta'],
      ['/pemerintahan', 'Pemerintahan ↗'],
    ].map(([href, label]) => (
      <a
        href={href}
        class="whitespace-nowrap px-3 py-1.5 rounded-full text-sm font-heading font-semibold border-2 border-line text-ink hover:border-accent transition-colors"
      >
        {label}
      </a>
    ))}
  </div>
</div>

<main id="main" class="mx-auto max-w-[1152px] px-4 sm:px-6 py-10 space-y-14">

  <!-- Stats -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
    {[
      { icon: 'users', label: 'Penduduk', value: fmt(totalPenduduk), sub: 'Jiwa' },
      { icon: 'layers', label: 'Wilayah', value: stUmum.luas ?? '-', sub: 'Hektar' },
      { icon: 'home', label: 'Dusun', value: String(dusunData.length), sub: 'Wilayah' },
      { icon: 'map-pin', label: 'RW / RT', value: `${stUmum.rw ?? '-'} / ${stUmum.rt ?? '-'}`, sub: 'Administratif' },
    ].map(tile => (
      <div class="bg-white border border-line rounded-2xl p-5 shadow-[0_4px_10px_rgba(15,36,51,.08)]">
        <i data-lucide={tile.icon} class="w-6 h-6 text-accent"></i>
        <p class="font-heading font-extrabold text-2xl text-primary mt-2">{tile.value}</p>
        <p class="text-xs font-heading font-semibold text-muted uppercase mt-0.5">{tile.sub}</p>
        <p class="text-sm text-ink mt-0.5">{tile.label}</p>
      </div>
    ))}
  </div>

  <!-- Umum -->
  <section id="umum" style="scroll-margin-top: 120px;">
    <h2 class="text-2xl font-heading font-extrabold text-primary">Profil Umum</h2>
    <p class="text-muted mt-2 max-w-3xl leading-relaxed">
      Desa Loji adalah desa pesisir yang terletak di Kecamatan Simpenan, Kabupaten Sukabumi, Provinsi Jawa Barat. Berbatasan langsung dengan Samudra Hindia di sebelah selatan, desa ini dikenal sebagai lumbung padi wilayah Palabuhanratu sekaligus bagian dari penyangga kawasan Geopark Ciletuh-Palabuhanratu.
    </p>
    <div class="prose max-w-none mt-4 text-muted leading-relaxed" set:html={umum?.content_html ?? ''} />
    <div class="grid sm:grid-cols-2 gap-4 mt-6">
      {[
        { label: 'Kecamatan', value: 'Simpenan' },
        { label: 'Kabupaten', value: 'Sukabumi' },
        { label: 'Provinsi', value: 'Jawa Barat' },
        { label: 'Kode Pos', value: '43361' },
      ].map(row => (
        <div class="flex justify-between py-3 border-b border-line">
          <span class="font-heading font-semibold text-ink">{row.label}</span>
          <span class="text-muted">{row.value}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Geografis -->
  <section id="geografis" style="scroll-margin-top: 120px;">
    <h2 class="text-2xl font-heading font-extrabold text-primary">Kondisi Geografis</h2>
    <p class="text-muted mt-2 max-w-3xl leading-relaxed">
      Secara geografis, Desa Loji berada di koordinat sekitar -7.059° LS, 106.578° BT. Wilayahnya meliputi kawasan pantai, bukit, dan hutan pesisir. Topografi bervariasi dari dataran rendah di pinggir pantai hingga perbukitan yang menjorok ke dalam.
    </p>
    <div class="prose max-w-none mt-4 text-muted leading-relaxed" set:html={geografis?.content_html ?? ''} />
    <div class="grid sm:grid-cols-3 gap-4 mt-6">
      {[
        { icon: 'mountain', label: 'Ketinggian', value: '0 sampai 250 m dpl' },
        { icon: 'thermometer', label: 'Iklim', value: 'Tropis Basah' },
        { icon: 'waves', label: 'Garis Pantai', value: '±4 km' },
      ].map(item => (
        <div class="bg-white border border-line rounded-xl p-5 shadow-[0_4px_10px_rgba(15,36,51,.08)]">
          <i data-lucide={item.icon} class="w-6 h-6 text-accent"></i>
          <p class="text-xs font-heading font-semibold text-muted uppercase mt-2">{item.label}</p>
          <p class="font-heading font-bold text-xl text-primary mt-0.5">{item.value}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Demografi (sumber: Profil Desa Loji / RPJMDes 2026 dan rekap penduduk April 2026) -->
  <section id="demografi" style="scroll-margin-top: 120px;">
    <h2 class="text-2xl font-heading font-extrabold text-primary">Demografi Penduduk</h2>
    <p class="text-muted mt-2 max-w-3xl leading-relaxed">
      Data kependudukan Desa Loji per dusun, golongan umur, tingkat pendidikan, dan mata pencaharian, berdasarkan rekapitulasi Pemerintah Desa Loji tahun 2026.
    </p>

    <div class="mt-6 space-y-10">

      <!-- Penduduk per dusun -->
      <div>
        <h3 class="font-heading font-bold text-lg text-primary mb-1">Penduduk per Dusun</h3>
        <div class="flex items-center gap-4 mb-3 text-sm text-muted">
          <span class="inline-flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm inline-block" style="background:var(--color-accent);"></span>Laki-laki</span>
          <span class="inline-flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm inline-block" style="background:var(--color-cta);"></span>Perempuan</span>
        </div>
        <div class="space-y-4">
          {dusunData.map(d => (
            <div>
              <div class="flex items-baseline justify-between mb-1">
                <span class="font-heading font-semibold text-sm text-ink">Dusun {d.label}</span>
                <span class="text-xs text-muted">{fmt(d.l + d.p)} jiwa · {fmt(d.kk)} KK</span>
              </div>
              <div class="flex items-center gap-2 mb-1">
                <div class="flex-1 h-5 rounded-md" style="background:var(--color-line);">
                  <div class="h-full" style={`width:${barPct(d.l, dusunMax)}%; background:var(--color-accent); border-radius:0 4px 4px 0;`}></div>
                </div>
                <span class="w-14 shrink-0 text-right text-xs font-heading font-semibold text-ink tabular-nums">{fmt(d.l)}</span>
              </div>
              <div class="flex items-center gap-2">
                <div class="flex-1 h-5 rounded-md" style="background:var(--color-line);">
                  <div class="h-full" style={`width:${barPct(d.p, dusunMax)}%; background:var(--color-cta); border-radius:0 4px 4px 0;`}></div>
                </div>
                <span class="w-14 shrink-0 text-right text-xs font-heading font-semibold text-ink tabular-nums">{fmt(d.p)}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Golongan umur -->
      <div>
        <h3 class="font-heading font-bold text-lg text-primary mb-3">Golongan Umur</h3>
        <div class="space-y-2">
          {umurData.map(d => (
            <div class="flex items-center gap-3">
              <span class="w-28 shrink-0 text-sm text-ink">{d.label}</span>
              <div class="flex-1 h-5 rounded-md" style="background:var(--color-line);">
                <div class="h-full" style={`width:${barPct(d.value, umurMax)}%; background:var(--color-accent); border-radius:0 4px 4px 0;`}></div>
              </div>
              <span class="w-14 shrink-0 text-right text-sm font-heading font-semibold text-primary tabular-nums">{fmt(d.value)}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Tingkat pendidikan -->
      <div>
        <h3 class="font-heading font-bold text-lg text-primary mb-3">Tingkat Pendidikan</h3>
        <div class="space-y-2">
          {pendidikanData.map(d => (
            <div class="flex items-center gap-3">
              <span class="w-40 shrink-0 text-sm text-ink">{d.label}</span>
              <div class="flex-1 h-5 rounded-md" style="background:var(--color-line);">
                <div class="h-full" style={`width:${barPct(d.value, pendidikanMax)}%; background:var(--color-accent); border-radius:0 4px 4px 0;`}></div>
              </div>
              <span class="w-14 shrink-0 text-right text-sm font-heading font-semibold text-primary tabular-nums">{fmt(d.value)}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Mata pencaharian -->
      <div>
        <h3 class="font-heading font-bold text-lg text-primary mb-3">Mata Pencaharian</h3>
        <div class="space-y-2">
          {pencaharianData.map(d => (
            <div class="flex items-center gap-3">
              <span class="w-52 shrink-0 text-sm text-ink">{d.label}</span>
              <div class="flex-1 h-5 rounded-md" style="background:var(--color-line);">
                <div class="h-full" style={`width:${barPct(d.value, pencaharianMax)}%; background:var(--color-accent); border-radius:0 4px 4px 0;`}></div>
              </div>
              <span class="w-14 shrink-0 text-right text-sm font-heading font-semibold text-primary tabular-nums">{fmt(d.value)}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Tabel data (aksesibilitas) -->
      <details class="border border-line rounded-xl p-4">
        <summary class="font-heading font-semibold text-sm text-primary cursor-pointer">Lihat semua data dalam bentuk tabel</summary>
        <div class="mt-4 grid sm:grid-cols-2 gap-6 text-sm">
          <table class="w-full">
            <caption class="text-left font-heading font-semibold mb-1">Penduduk per Dusun</caption>
            <thead><tr class="text-muted text-xs"><th class="text-left font-normal py-1">Dusun</th><th class="text-right font-normal">L</th><th class="text-right font-normal">P</th><th class="text-right font-normal">KK</th></tr></thead>
            <tbody>
              {dusunData.map(d => (
                <tr class="border-t border-line"><td class="py-1">{d.label}</td><td class="text-right tabular-nums">{fmt(d.l)}</td><td class="text-right tabular-nums">{fmt(d.p)}</td><td class="text-right tabular-nums">{fmt(d.kk)}</td></tr>
              ))}
            </tbody>
          </table>
          <table class="w-full">
            <caption class="text-left font-heading font-semibold mb-1">Golongan Umur</caption>
            <tbody>
              {umurData.map(d => (
                <tr class="border-t border-line"><td class="py-1">{d.label}</td><td class="text-right tabular-nums">{fmt(d.value)}</td></tr>
              ))}
            </tbody>
          </table>
          <table class="w-full">
            <caption class="text-left font-heading font-semibold mb-1">Tingkat Pendidikan</caption>
            <tbody>
              {pendidikanData.map(d => (
                <tr class="border-t border-line"><td class="py-1">{d.label}</td><td class="text-right tabular-nums">{fmt(d.value)}</td></tr>
              ))}
            </tbody>
          </table>
          <table class="w-full">
            <caption class="text-left font-heading font-semibold mb-1">Mata Pencaharian</caption>
            <tbody>
              {pencaharianData.map(d => (
                <tr class="border-t border-line"><td class="py-1">{d.label}</td><td class="text-right tabular-nums">{fmt(d.value)}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </details>

    </div>
  </section>

  <!-- Sejarah -->
  <section id="sejarah" style="scroll-margin-top: 120px;">
    <h2 class="text-2xl font-heading font-extrabold text-primary">Sejarah Desa</h2>
    <div class="prose max-w-none mt-4 text-muted leading-relaxed" set:html={sejarah?.content_html ?? `
      <p>Desa Loji memiliki sejarah panjang sebagai perkampungan nelayan di tepi Samudra Hindia. Nama "Loji" diyakini berasal dari bangunan loji peninggalan masa kolonial yang pernah berdiri di kawasan ini. Masyarakat desa secara turun-temurun hidup dari hasil laut dan pertanian pesisir.</p>
      <p>Posisi strategis Desa Loji sebagai gerbang Geopark Ciletuh mulai membuka babak baru bagi perekonomian desa, dengan pariwisata menjadi sektor yang terus berkembang di samping perikanan tradisional yang menjadi tulang punggung.</p>
    `} />
  </section>

  <!-- Peta -->
  <section id="peta" style="scroll-margin-top: 120px;">
    <h2 class="text-2xl font-heading font-extrabold text-primary">Peta Desa</h2>
    <p class="text-muted mt-2">Lokasi Desa Loji di Kecamatan Simpenan, Kabupaten Sukabumi.</p>
    <div id="profil-map" class="mt-4 rounded-2xl overflow-hidden border border-line shadow-[0_4px_10px_rgba(15,36,51,.08)]" style="height: 380px;"></div>
    <p class="text-sm text-muted mt-2 flex items-center gap-1.5">
      <i data-lucide="info" class="w-4 h-4"></i>
      Koordinat: -7.059, 106.578 ·
      <a href="/peta" class="text-accent hover:underline font-medium">Buka peta interaktif lengkap →</a>
    </p>
  </section>

  <!-- CTA Pemerintahan -->
  <section style="scroll-margin-top: 120px;">
    <div class="bg-primary text-white rounded-2xl p-8 flex flex-col sm:flex-row items-center gap-6">
      <div class="flex-1">
        <h2 class="text-2xl font-heading font-extrabold">Pemerintahan Desa</h2>
        <p class="text-white/80 mt-2">Pelajari struktur organisasi, perangkat desa, visi misi, dan tugas fungsi pemerintahan Desa Loji.</p>
      </div>
      <a href="/pemerintahan" class="inline-flex items-center gap-2 bg-white text-primary font-heading font-semibold px-6 py-3 rounded-lg hover:bg-sand transition-colors min-h-[44px] shrink-0">
        <i data-lucide="landmark" class="w-5 h-5"></i> Lihat Pemerintahan
      </a>
    </div>
  </section>

</main>

</Layout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var map = L.map('profil-map', { scrollWheelZoom: false }).setView([-7.0589, 106.5778], 14);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' }).addTo(map);
    L.marker([-7.0589, 106.5778]).addTo(map).bindPopup('<b>Desa Loji</b><br>Kec. Simpenan, Sukabumi');
    if (typeof lucide !== 'undefined') lucide.createIcons();
  });
  setTimeout(function() {
    if (typeof lucide !== 'undefined') lucide.createIcons();
  }, 300);
</script>

<style>
  .prose p { margin: .5rem 0; line-height: 1.75; }
  .prose h3 { font-family: 'Lexend', sans-serif; font-weight: 700; color: #0E4A6E; margin: 1rem 0 .5rem; }
  [id] { scroll-margin-top: 120px; }
</style>

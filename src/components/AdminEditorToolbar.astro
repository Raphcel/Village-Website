---
// Toolbar bersama untuk editor contenteditable admin.
// Halaman pemakai wajib memanggil initEditor() dari src/scripts/admin-editor.ts.
interface Props { withImage?: boolean }
const { withImage = false } = Astro.props;

const textCmds = [
  ['bold', 'B', 'Tebal'],
  ['italic', 'I', 'Miring'],
  ['underline', 'U', 'Garis bawah'],
];
const blockCmds = [
  ['insertUnorderedList', 'Daftar •', 'Daftar poin'],
  ['insertOrderedList', 'Daftar 1.', 'Daftar bernomor'],
  ['formatBlock-h2', 'Sub-judul', 'Sub-judul (H2)'],
];
---

<div class="border rounded-t-lg px-2 py-1.5 flex gap-1 flex-wrap" style="border-color:var(--color-border); background:#F8FAFC;">
  {textCmds.map(([cmd, lbl, title]) => (
    <button type="button" data-cmd={cmd} title={title} aria-label={title}
      class="px-2 py-1 text-xs font-heading font-semibold rounded hover:bg-sand transition-colors cursor-pointer border border-border">
      {lbl}
    </button>
  ))}
  <span class="w-px bg-border mx-1"></span>
  {blockCmds.map(([cmd, lbl, title]) => (
    <button type="button" data-cmd={cmd} title={title}
      class="px-2 py-1 text-xs font-heading rounded hover:bg-sand transition-colors cursor-pointer border border-border">
      {lbl}
    </button>
  ))}
  {withImage && (
    <>
      <span class="w-px bg-border mx-1"></span>
      <button type="button" data-cmd="image" title="Sisipkan gambar di posisi kursor"
        class="px-2 py-1 text-xs font-heading rounded hover:bg-sand transition-colors cursor-pointer border border-border">
        🖼 Gambar
      </button>
    </>
  )}
</div>

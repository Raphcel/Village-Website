---
interface Props {
  variant?: 'primary' | 'secondary';
  href?: string;
  type?: 'button' | 'submit';
  class?: string;
  [key: string]: unknown;
}

const {
  variant = 'primary',
  href,
  type = 'button',
  class: className,
  ...rest
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 min-h-[44px] px-6 py-3 rounded-[2px] font-heading font-semibold text-base cursor-pointer transition-[background-color,color,box-shadow,border-color] duration-200 focus-visible:outline focus-visible:outline-[3px] focus-visible:outline-accent focus-visible:outline-offset-2';

const variants = {
  primary:
    'bg-cta text-white border-2 border-transparent hover:bg-[#126B33] hover:shadow-md',
  secondary:
    'bg-transparent text-primary border-2 border-primary hover:bg-primary hover:text-white',
};

const classes = [base, variants[variant], className].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} {...rest}>
    <slot />
  </button>
)}
